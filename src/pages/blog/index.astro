---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Injection de l'équation de routage
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${basePath}/${path.replace(/^\//, '')}`;
---

<Layout title="Blog Personnel | Alain Didier Noutchegueme">
  <main class="max-w-[800px] mx-auto px-6 py-24 md:py-32">
    
    <a href="/" class="group inline-flex items-center text-xs font-mono tracking-widest text-zinc-400 hover:text-zinc-900 mb-16 transition-colors uppercase">
      <svg class="w-3 h-3 mr-2 opacity-50 group-hover:opacity-100 group-hover:-translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Retour à l'accueil
    </a>

    <header class="mb-16 border-b border-zinc-200/60 pb-10">
      <h1 class="text-4xl md:text-5xl font-medium text-zinc-900 tracking-tight leading-[1.1] mb-6">
        Gueyordim (Blog de productivité)
      </h1>
      <p class="text-[1.1rem] text-zinc-600 leading-[1.8] font-light max-w-2xl">
        Archives et essais. Productivité. Discipline. Consistance. Modélisation de l'effort. Ingénierie de la pensée.
      </p>
    </header>

    <section class="mb-24">
      <div class="relative overflow-hidden p-8 md:p-12 rounded-[2rem] bg-zinc-50 border border-zinc-200/50 hover:border-zinc-300 transition-colors group">
        
        <div class="absolute -right-8 -top-8 text-zinc-100 group-hover:text-zinc-200 transition-colors rotate-12 pointer-events-none">
          <svg class="w-64 h-64" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        </div>
        
        <div class="relative z-10 md:w-2/3">
          <div class="flex items-center gap-3 mb-6">
            <span class="flex h-2 w-2 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
            </span>
            <span class="text-[10px] font-mono text-zinc-400 uppercase tracking-widest">En libre accès</span>
          </div>
          
          <h2 class="text-2xl md:text-3xl font-medium text-zinc-900 tracking-tight leading-snug mb-4">
            Ebooks & Architectures de Travail
          </h2>
          <p class="text-zinc-600 font-light leading-relaxed mb-8">
            Modélisation de l'effort, méthodologie de recherche accélérée et ingénierie de la cognition. Les trois ouvrages fondamentaux pour paramétrer votre machine de travail.
          </p>
          
          <a href="/ebooks" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-zinc-900 text-white text-sm font-medium hover:bg-zinc-800 transition-all shadow-sm group-hover:shadow-md">
            Accéder à la bibliothèque gratuite
            <svg class="w-4 h-4 ml-2 opacity-70 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="mb-8 relative">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </div>
      <input 
        type="search" 
        id="search-input" 
        placeholder="Rechercher un essai par titre ou mot-clé..." 
        class="w-full bg-white border border-zinc-200 text-zinc-900 px-12 py-4 rounded-2xl focus:outline-none focus:border-zinc-400 focus:ring-1 focus:ring-zinc-400 transition-all font-light placeholder-zinc-400 shadow-sm"
      />
      <div id="no-results" class="hidden absolute top-full left-0 mt-4 text-sm text-zinc-500 font-light">
        Aucun essai trouvé pour cette requête.
      </div>
    </section>

    <div id="articles-container" class="space-y-4">
      {sortedPosts.map((post) => (
        <a 
          href={`/blog/${post.id}`} 
          class="article-card group block p-6 rounded-2xl bg-white/40 border border-zinc-200/40 hover:bg-white hover:border-zinc-300 hover:shadow-sm transition-all"
          data-search={`${post.data.title} ${post.data.description}`.toLowerCase()}
        >
          <div class="flex flex-col md:flex-row md:items-baseline justify-between gap-2 mb-2">
            <h2 class="text-lg font-medium text-zinc-900 group-hover:text-blue-600 transition-colors">{post.data.title}</h2>
            <span class="text-[10px] font-mono text-zinc-400 uppercase tracking-widest shrink-0">
              {post.data.publishDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
          </div>
          <p class="text-sm text-zinc-500 font-light leading-relaxed">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>

  <script is:inline>
    const searchInput = document.getElementById('search-input');
    const articles = document.querySelectorAll('.article-card');
    const noResultsMsg = document.getElementById('no-results');

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        let visibleCount = 0;

        articles.forEach(article => {
          const searchableText = article.getAttribute('data-search');
          if (searchableText.includes(query)) {
            article.style.display = 'block';
            visibleCount++;
          } else {
            article.style.display = 'none';
          }
        });

        // Affichage du message si aucun résultat
        if (visibleCount === 0 && query !== '') {
          noResultsMsg.classList.remove('hidden');
        } else {
          noResultsMsg.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>