---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Alain Didier Noutchegueme | Chercheur, Stratège IA, Écrivain">
  
  <!-- FOND DYNAMIQUE SUBTIL -->
  <div class="fixed top-0 inset-x-0 h-[800px] bg-gradient-to-b from-blue-50/60 via-purple-50/10 to-transparent z-[-2] pointer-events-none"></div>
  <div class="fixed inset-0 z-[-1] opacity-[0.015] pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

  <main class="max-w-[1100px] mx-auto px-6 py-24 md:py-32">
    
    <!-- EN-TÊTE INTACT -->
    <header class="mb-24 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 tracking-tight leading-[1.1] mb-6">
        Alain Didier Noutchegueme
      </h1>
      <div class="flex flex-wrap justify-center items-center gap-3 text-sm md:text-base font-mono text-zinc-500 uppercase tracking-widest">
        <span>Chercheur</span>
        <span class="text-zinc-300">•</span>
        <span>Conférencier</span>
        <span class="text-zinc-300">•</span>
        <span>Écrivain</span>
      </div>
    </header>

    <!-- HÉRO : ARCHITECTURE DE LA PENSÉE -->
    <section class="flex flex-col-reverse md:flex-row items-center gap-12 md:gap-20 mb-32">
      
      <!-- Colonne Gauche : Curriculum Analytique avec Navigation Intégrée -->
      <div class="w-full md:w-1/2">
        <div class="border-l border-zinc-200/80 pl-6 md:pl-8 space-y-12">
          
          <!-- Élément 1 : Chercheur -->
          <div class="relative group">
            <span class="absolute -left-[25px] md:-left-[33px] top-1.5 w-1.5 h-1.5 bg-zinc-300 rounded-full transition-colors group-hover:bg-blue-400"></span>
            <h3 class="text-lg font-medium text-zinc-900 mb-2">PhD Candidate en Mathématiques</h3>
            <p class="text-sm text-zinc-600 font-light leading-relaxed mb-3">
              Géométrie spectrale. Recherche fondamentale sur la manière dont les formes influencent la physique.
            </p>
            <a href="/recherche" class="inline-flex items-center text-xs font-medium text-zinc-400 hover:text-blue-600 transition-colors">
              Travaux académiques 
              <svg class="w-3 h-3 ml-1.5 transform translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Élément 2 : Stratégie IA -->
          <div class="relative group">
            <span class="absolute -left-[25px] md:-left-[33px] top-1.5 w-1.5 h-1.5 bg-zinc-300 rounded-full transition-colors group-hover:bg-blue-400"></span>
            <h3 class="text-lg font-medium text-zinc-900 mb-2">Mathématiques, Intelligence Artificielle & Géopolitique</h3>
            <p class="text-sm text-zinc-600 font-light leading-relaxed mb-3">
              Compétences multidisciplinaires transversales. Analyse systémique. Conception d'agents IA. Conférences données sur 3 continents.
            </p>
            <a href="/consultation" class="inline-flex items-center text-xs font-medium text-zinc-400 hover:text-blue-600 transition-colors">
              Explorer l'architecture 
              <svg class="w-3 h-3 ml-1.5 transform translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Élément 3 : Écrivain -->
          <div class="relative group">
            <span class="absolute -left-[25px] md:-left-[33px] top-1.5 w-1.5 h-1.5 bg-zinc-300 rounded-full transition-colors group-hover:bg-blue-400"></span>
            <h3 class="text-lg font-medium text-zinc-900 mb-2">Auteur de l'ouvrage "Le Kit de Survie"</h3>
            <p class="text-sm text-zinc-600 font-light leading-relaxed mb-3">
              Ingénierie du travail profond. Comprendre le monde universitaire pour s'orienter. L'Excellence académique et humaine.
            </p>
            
            <a href="/blog" class="inline-flex items-center text-xs font-medium text-zinc-400 hover:text-blue-600 transition-colors">
              Lire plus d'essais 
              <svg class="w-3 h-3 ml-1.5 transform translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            
          </div>

        </div>

        <div class="mt-14 pl-6 md:pl-8">
          <a href="/manifeste" class="inline-flex items-center text-sm font-medium text-zinc-900 hover:text-blue-600 transition-colors group">
            <span class="border-b border-zinc-900 group-hover:border-blue-600 transition-colors pb-0.5">Ma vision du monde</span>
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>

      <!-- Colonne Droite : Portrait Éditorial -->
      <div class="w-full md:w-1/2">
        <div class="rounded-2xl overflow-hidden border border-zinc-200 shadow-[0_8px_30px_rgb(0,0,0,0.04)] bg-zinc-100">
          <img src="/AlainDidier2.jpg" alt="Alain Didier Noutchegueme" class="w-full h-auto object-cover grayscale-[10%] contrast-[1.02]" />
        </div>
      </div>

    </section>

    <!-- PREUVE D'AUTORITÉ (Vidéo Unique) -->
    <section class="mb-32">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-lg font-medium text-zinc-900">Intervention publique</h2>
          <a href="/vulgarisation" class="text-xs font-mono text-zinc-400 uppercase tracking-widest hover:text-zinc-900 transition-colors">Visionner l'archive</a>
        </div>
        
        <div class="w-full aspect-video rounded-2xl overflow-hidden border border-zinc-200/80 shadow-sm bg-zinc-50">
          <iframe 
            class="w-full h-full" 
            src="https://www.youtube.com/embed/wLvYBmoNF5Y" 
            title="L'humain et les mathématiques, la vie des mathématiques" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen>
          </iframe>
        </div>
      </div>
    </section>

    <!-- NEWSLETTER : La Lettre (Design d'ingénierie) -->
    <section class="border-t border-zinc-200/80 pt-20">
      <div class="max-w-3xl mx-auto text-center">
        
        <span class="inline-block text-[10px] font-mono text-zinc-500 uppercase tracking-widest border border-zinc-200 px-3 py-1 rounded-md mb-6">
          Mailing List
        </span>
        
        <h2 class="text-3xl font-medium text-zinc-900 tracking-tight mb-4">
          Naviguer avec moi le monde incertain de l'IA
        </h2>
        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-10">
          Mon approche est globale. Ce qui m'obsède c'est de comprendre en profondeur comment bâtir des architectures robustes et évolutives. Pas de conseils du types : "03 hacks pour économiser ses tokens sur Claude".
        </p>
        
        <form 
          action="https://embeds.beehiiv.com/dd1c3d30-98c3-4f3f-8731-ae0fcb25e9d4" 
          method="POST" 
          target="_blank"
          class="flex flex-col sm:flex-row items-center gap-3 max-w-md mx-auto"
          >
          <input 
            type="email" 
            name="email"
            placeholder="Adresse email" 
            class="w-full sm:w-2/3 bg-white border border-zinc-200 text-zinc-900 px-5 py-3 rounded-xl focus:outline-none focus:border-zinc-400 focus:ring-1 focus:ring-zinc-400 transition-all font-light text-sm placeholder-zinc-400 shadow-sm"
            required
          />
          <button 
            type="submit" 
            class="w-full sm:w-1/3 bg-zinc-900 text-white font-medium px-5 py-3 rounded-xl hover:bg-zinc-800 transition-colors text-sm shadow-sm"
          >
            S'inscrire
          </button>
        </form>
        <p class="text-[10px] text-zinc-400 font-mono mt-6 uppercase tracking-wider">Désinscription en un clic.</p>
        
      </div>
    </section>

  </main>
</Layout>